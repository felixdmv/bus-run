# -----------------------------------------------------------------------------
# MetroMile - Variables de Entorno de Ejemplo
# Copia este archivo como '.env' o '.env.local' para desarrollo local.
# -----------------------------------------------------------------------------

# --- CLIENT-SIDE (VITE) ---
# ID de Cliente de tu aplicación de Strava (debe empezar con VITE_ para exponerse al navegador)
# Consíguelo en https://www.strava.com/settings/api
VITE_STRAVA_CLIENT_ID=tu_strava_client_id_aqui

# URL e ID anónimo de Supabase (Mapeado por defecto si usas la integración de Vercel)
# VITE_SUPABASE_URL=tu_supabase_url_aqui
# VITE_SUPABASE_ANON_KEY=tu_supabase_anon_key_aqui


# --- SERVER-SIDE (PROXY DE VERCEL) ---
# Las siguientes variables no llevan el prefijo VITE_ y solo se exponen en las funciones de Vercel.
STRAVA_CLIENT_ID=tu_strava_client_id_aqui
STRAVA_CLIENT_SECRET=tu_strava_client_secret_aqui
